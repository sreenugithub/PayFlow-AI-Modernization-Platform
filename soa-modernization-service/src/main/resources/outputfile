      "path": "src/main/java/com/example/paymentvalidation/service/PaymentValidationService.java",
      "content": "package com.example.paymentvalidation.service;\n\nimport com.example.paymentvalidation.client.AccountValidationClient;\nimport com.example.paymentvalidation.dto.AccountValidationResult;\nimport com.example.paymentvalidation.dto.PaymentValidationRequest;\nimport com.example.paymentvalidation.dto.PaymentValidationResponse;\nimport com.example.paymentvalidation.exception.ExternalServiceException;\nimport com.example.paymentvalidation.exception.InvalidPaymentException;\nimport org.springframework.stereotype.Service;\n\n@Service\npublic class PaymentValidationService {\n\n    private final AccountValidationClient accountValidationClient;\n\n    public PaymentValidationService(AccountValidationClient accountValidationClient) {\n        this.accountValidationClient = accountValidationClient;\n    }\n\n    public PaymentValidationResponse validatePayment(PaymentValidationRequest request) {\n        if (request.getAmount() == null || request.getAmount() <= 0) {\n            throw new InvalidPaymentException(\"Amount must be greater than zero\");\n        }\n        if (request.getPaymentReference() == null || request.getPaymentReference().isBlank()) {\n            throw new InvalidPaymentException(\"Payment reference is required\");\n        }\n        if (request.getPaymentType() == null || request.getPaymentType().isBlank()) {\n            throw new InvalidPaymentException(\"Payment type is required\");\n        }\n\n        try {\n            AccountValidationResult accountValidationResult = accountValidationClient.validateAccount(request);\n            boolean approved = accountValidationResult.isAccountValid() && request.getAmount() <= accountValidationResult.getAvailableLimit();\n\n            String status = approved ? \"APPROVED\" : \"REJECTED\";\n            String reason = approved ? \"Payment validated successfully\" : accountValidationResult.getMessage();\n\n            return new PaymentValidationResponse(\n                    request.getPaymentReference(),\n                    request.getPaymentType(),\n                    request.getAmount(),\n                    status,\n                    reason\n            );\n        } catch (RuntimeException ex) {\n            throw new ExternalServiceException(\"Failed to validate account with downstream service\", ex);\n        }\n    }\n}\n"
