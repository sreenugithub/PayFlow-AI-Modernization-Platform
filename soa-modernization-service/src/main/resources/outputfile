      "content": "package com.example.paymentvalidation.client;\n\nimport com.example.paymentvalidation.dto.AccountValidationResult;\nimport com.example.paymentvalidation.dto.PaymentValidationRequest;\nimport org.springframework.beans.factory.annotation.Value;\nimport org.springframework.stereotype.Component;\nimport org.springframework.web.reactive.function.client.WebClient;\n\n@Component\npublic class AccountValidationClient {\n\n    private final WebClient webClient;\n\n    public AccountValidationClient(WebClient.Builder builder, @Value(\"${downstream.account-validation.base-url:http://localhost:8081}\") String baseUrl) {\n        this.webClient = builder.baseUrl(baseUrl).build();\n    }\n\n    public AccountValidationResult validateAccount(PaymentValidationRequest request) {\n        return webClient.post()\n                .uri(\"/api/accounts/validate\")\n                .bodyValue(request)\n                .retrieve()\n                .bodyToMono(AccountValidationResult.class)\n                .block();\n    }\n}\n"
