      "content": "package com.example.paymentvalidation.service;\n\nimport com.example.paymentvalidation.client.AccountValidationClient;\nimport com.example.paymentvalidation.dto.AccountValidationResult;\nimport com.example.paymentvalidation.dto.PaymentValidationRequest;\nimport com.example.paymentvalidation.dto.PaymentValidationResponse;\nimport org.junit.jupiter.api.Test;\nimport org.mockito.Mockito;\n\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertThrows;\n\nclass PaymentValidationServiceTest {\n\n    private final AccountValidationClient client = Mockito.mock(AccountValidationClient.class);\n    private final PaymentValidationService service = new PaymentValidationService(client);\n\n    @Test\n    void shouldApprovePaymentWhenAccountIsValidAndLimitIsEnough() {\n        Mockito.when(client.validateAccount(Mockito.any()))\n                .thenReturn(new AccountValidationResult(true, 1000.0, \"OK\"));\n\n        PaymentValidationResponse response = service.validatePayment(new PaymentValidationRequest(\"REF-1\", \"CARD\", 250.0));\n\n        assertEquals(\"APPROVED\", response.getStatus());\n        assertEquals(\"Payment validated successfully\", response.getMessage());\n    }\n\n    @Test\n    void shouldRejectPaymentWhenLimitIsTooLow() {\n        Mockito.when(client.validateAccount(Mockito.any()))\n                .thenReturn(new AccountValidationResult(true, 100.0, \"Limit insufficient\"));\n\n        PaymentValidationResponse response = service.validatePayment(new PaymentValidationRequest(\"REF-2\", \"CARD\", 250.0));\n\n        assertEquals(\"REJECTED\", response.getStatus());\n        assertEquals(\"Limit insufficient\", response.getMessage());\n    }\n\n    @Test\n    void shouldThrowWhenAmountInvalid() {\n        assertThrows(RuntimeException.class, () -> service.validatePayment(new PaymentValidationRequest(\"REF-3\", \"CARD\", 0.0)));\n    }\n}\n"
